##################################
# Frontend Environment Variables #
##################################

# API Configuration
# Use single-level subdomains for Cloudflare Free tier proxy support
# Format: dev-api.domain.com or api.domain.com
KK_API_URL=https://dev-api.krakenkey.io

# ACME Configuration
# This is the auth zone domain for ACME DNS-01 challenge delegation
# Can be single or multi-level (DNS-only, no SSL proxy needed)
KK_ACME_AUTH_ZONE_DOMAIN=acme.krakenkey.io

# Vite Development Server
# Domain allowed for the Vite dev server
# Use single-level subdomain for Cloudflare Free tier
VITE_ALLOWED_HOST=dev-web.krakenkey.io
