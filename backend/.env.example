##################################
# Backend Environment Variables  #
##################################

##  General ##
API_VERSION=0.0.1
NODE_ENV=dev
PORT=8888
KK_API_PORT=8080

#
##  Domain Configuration ##
# These should be single-level subdomains for Cloudflare Free tier proxy support
# Use environment prefix format: dev-{service}.domain.com or prod-{service}.domain.com
KK_APP_DOMAIN=dev-web.krakenkey.io
ACME_AUTH_ZONE_DOMAIN=acme.krakenkey.io
ACME_CONTACT_EMAIL=admin@yourdomain.com

#
##  Postgres DB ##
KK_DB_HOST=krakenkey-db-dev
KK_DB_PORT=5432
KK_DB_USERNAME=postgres
KK_DB_PASSWORD=your_secure_password_here
KK_DB_DATABASE=krakenkey
KK_DB_LOGGING=true
KK_DB_SYNCHRONIZE=true
KK_DB_SSL=false

#
##  BullMQ Redis ##
KK_BULLMQ_HOST=krakenkey-redis-dev
KK_BULLMQ_PORT=6379
KK_BULLMQ_PASSWORD=

#
## DNS Provider Credentials ##
# Cloudflare
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here

# Route53 (optional - for AWS DNS)
# AWS_ACCESS_KEY_ID=your_aws_access_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
# AWS_REGION=us-east-1

#
## ACME / Let's Encrypt ##
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096 -out acme-account.key
# Then convert to single-line format with \n for newlines
ACME_ACCOUNT_KEY='-----BEGIN PRIVATE KEY-----\nYOUR_ACME_ACCOUNT_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n'

#
## Authentication / OIDC (Authentik) ##
# Use single-level subdomains: dev-auth.domain.com or auth.domain.com
KK_AUTHENTIK_DOMAIN=auth-dev.krakenkey.io
KK_AUTHENTIK_ENROLLMENT_SLUG=krakenkey
KK_AUTHENTIK_ISSUER_URL=https://auth-dev.krakenkey.io/application/o/krakenkey/
KK_AUTHENTIK_CLIENT_ID=krakenkey-backend
KK_AUTHENTIK_CLIENT_SECRET=your_authentik_client_secret_here
KK_AUTHENTIK_REDIRECT_URI=https://api-dev.krakenkey.io/auth/callback
KK_AUTHENTIK_POST_ENROLLMENT_REDIRECT=https://api-dev.krakenkey.io/auth/login
